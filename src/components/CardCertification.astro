---
import IconEye from "./icons/IconEye.astro";

const { title, institution, date, description } = Astro.props.certification;
---

<article
  class="flex justify-between bg-carbon/50 border-2 border-gray-600/80 rounded-lg w-full px-9 py-7
  hover:-translate-y-1 hover:border-gray-600 hover:shadow-sm hover:shadow-gray-700/50
           transition duration-200 ease-in-out timeline-view animate-fade-in-right animate-range-[entry_10%_cover_35%]"
>
  <div>
    <h4 class="text-slate-100 text-2xl font-bold tracking-wide">
      {title}
    </h4>

    <span class="text-Sprimary-600 text-lg font-semibold tracking-wide">
      {institution}
    </span>
    <p class="text-slate-200 text-md tracking-wide mt-2 text-pretty w-[85ch]">
      {description}
    </p>
    <button
      class="flex gap-2 text-slate-950 px-3 py-2 bg-blue-100/90 rounded-md mt-4 font-semibold text-md items-center transition-colors hover:bg-blue-200/90"
      >Ver <IconEye /></button
    >
  </div>
  <div>
    <p class="text-blue-100/90 text-md tracking-wide">
      {date}
    </p>
  </div>
</article>
