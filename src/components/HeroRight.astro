---
import perfil from "../assets/Perfil-portafolios-EDIT.webp";
---

<figure
  class="animate-blurred-fade-in animate-delay-250 w-100 h-auto -translate-y-8 p-1 border-2 rounded-2xl border-Sprimary-700 rotate-3 shadow-lg shadow-Sprimary-700/30 hover:rotate-0 transition-transform duration-300 ease-out bg-linear-to-bl from-red-400/10 via-blue-300/10 to-slate-900/10 overflow-hidden"
>
  <img
    src={perfil.src}
    alt="Foto de perfil de Sergio Hernández"
    class="rounded-full w-full h-auto object-cover object-center mask-b-from-40% mask-b-to-90%"
  />
</figure>
<style>
  img {
    clip-path: inset(0 0 20px 0); /* arriba | derecha | abajo | izquierda */
  }
</style>
